# Supabase (проект Marketing agency, схема information_analysis_agent)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# LLM (тот же ключ, что и у Агента 1/Агента 2 — общий OpenRouter аккаунт цепочки)
OPENROUTER_API_KEY=

# Redis (общий контейнер агентов; localhost при запуске вне Docker, redis://redis:6379 внутри Docker)
REDIS_URL=

# Telegram (тот же пользователь, что уже настроен у Агента 1)
TELEGRAM_ALLOWED_USER_ID=

# Эмбеддинги (тот же ключ, что и у Агента 2 — общий Google-аккаунт)
GEMINI_API_KEY=

# Наблюдаемость — LangSmith (трейсинг графа) и Helicone (прокси-логирование LLM-вызовов).
# Опционально: без этих переменных агент работает как раньше, без трейсинга.
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=
HELICONE_API_KEY=
