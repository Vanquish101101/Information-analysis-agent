# Supabase (проект Marketing agency, схема information_analysis_agent)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# LLM (тот же ключ, что и у Агента 1/Агента 2 — общий OpenRouter аккаунт цепочки)
OPENROUTER_API_KEY=

# Redis (общий контейнер агентов; localhost при запуске вне Docker, redis://redis:6379 внутри Docker)
REDIS_URL=

# Telegram (тот же пользователь, что уже настроен у Агента 1)
TELEGRAM_ALLOWED_USER_ID=

# Эмбеддинги (тот же ключ, что и у Агента 2 — общий Google-аккаунт)
GEMINI_API_KEY=

# Наблюдаемость — LangSmith (трейсинг графа) и Helicone (прокси-логирование LLM-вызовов).
# Опционально: без этих переменных агент работает как раньше, без трейсинга.
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=
HELICONE_API_KEY=

# Агент 2 (Deep Parsing Agent) — MCP Streamable HTTP, для автоповтора низкоуверенных item'ов (Шаг 7).
# Внутри Docker-сети: http://deep-parsing-agent:7301 (подтвердить при живой проверке).
DEEP_PARSING_AGENT_URL=

# MCP-сервер Агента 3 (выход для Агента 4) — Streamable HTTP, порт по умолчанию 7302.
MCP_HTTP_PORT=

# Telegram-уведомления (Шаг 10) — переиспользует токен бота Агента 1 (общий бот на всю цепочку),
# не отдельная регистрация. TELEGRAM_ALLOWED_USER_ID уже есть выше — используется как chat_id.
TELEGRAM_BOT_TOKEN=
